{
  "v": 1,
  "id": "cursor",
  "enableEnvVar": "HAPPIER_E2E_PROVIDER_CURSOR",
  "protocol": "acp",
  "traceProvider": "cursor",
  "requiredBinaries": [
    {
      "bin": "cursor-agent",
      "envOverride": "HAPPIER_E2E_PROVIDER_CURSOR_BIN",
      "requireExists": true
    }
  ],
  "auth": {
    "mode": "auto",
    "env": {
      "requiredAnyOf": [["CURSOR_API_KEY"]]
    }
  },
  "permissions": {
    "v": 1,
    "acp": {
      "toolPermissionPromptsByMode": {
        "default": false,
        "safe-yolo": false,
        "read-only": false,
        "yolo": false,
        "plan": false
      },
      "outsideWorkspaceWriteAllowedByMode": {
        "default": false,
        "safe-yolo": false,
        "read-only": false,
        "yolo": false,
        "plan": false
      },
      "outsideWorkspaceWriteMustCompleteByMode": {
        "default": false,
        "safe-yolo": false,
        "read-only": false,
        "yolo": false,
        "plan": false
      },
      "outsideWorkspaceRequireTaskCompleteByMode": {
        "default": false,
        "safe-yolo": false,
        "read-only": false,
        "yolo": false,
        "plan": false
      },
      "expectToolPermissionPrompts": false,
      "permissionSurfaceOutsideWorkspaceYolo": false
    }
  },
  "cli": {
    "subcommand": "cursor",
    "extraArgs": ["--started-by", "terminal"],
    "env": {
      "HEADLESS": "1",
      "HAPPIER_VARIANT": "dev"
    },
    "envFrom": {
      "HAPPIER_CURSOR_PATH": "HAPPIER_E2E_PROVIDER_CURSOR_BIN"
    }
  }
}
