# Happier Server environment template
# Copy this file to your deployment secret manager or local .env.
# Example local usage:
#   cp apps/server/.env.example apps/server/.env
#
# Notes:
# - This template is production-oriented for full flavor (Postgres + S3).
# - For light flavor, see the "Light flavor overrides" section below.
# - Legacy HAPPY_* aliases are not listed; prefer HAPPIER_* variables.

############################
# Core runtime
############################
NODE_ENV=production
PORT=3005
HAPPIER_SERVER_HOST=0.0.0.0
SERVER_ROLE=all
HAPPIER_DB_PROVIDER=postgres
DATABASE_URL=postgresql://user:password@db:5432/happier?sslmode=require
HANDY_MASTER_SECRET=replace-with-a-long-random-secret
HAPPIER_FILES_BACKEND=s3
HAPPIER_SOCKET_ADAPTER=memory
METRICS_ENABLED=true
METRICS_PORT=9090
# Optional stable process id (helpful in clustered deployments)
# HAPPIER_INSTANCE_ID=api-1

############################
# Canonical URLs (recommended)
############################
# Canonical/share server URL embedded in QR/deep links and advertised to clients via GET /v1/features.
# Set this to the URL your phone can reach (prefer https://).
# HAPPIER_PUBLIC_SERVER_URL=https://api.example.com
#
# Web app base URL (OAuth return-to and client base). Optional if you use https://app.happier.dev.
# If you self-host the UI, set this to your UI origin (often the same as HAPPIER_PUBLIC_SERVER_URL).
# HAPPIER_WEBAPP_URL=https://app.example.com

############################
# Networking / reverse proxy (optional)
############################
# Controls whether the server trusts X-Forwarded-* headers for client IP / protocol.
# Recommended behind a single reverse proxy (nginx/traefik/caddy): set to 1.
# WARNING: Do not enable unless the server is not directly reachable by untrusted clients.
# HAPPIER_SERVER_TRUST_PROXY=1
#
# To trust all proxy hops (only safe when the server is not directly reachable):
# HAPPIER_SERVER_TRUST_PROXY=true

############################
# API rate limiting (optional but recommended)
############################
# Master enable/disable for all API rate limits.
HAPPIER_API_RATE_LIMITS_ENABLED=true
# Global storm-shield (recommended): cap total requests per client IP across all routes.
# Set to 0 to disable.
#
# Recommended baseline for self-hosted deployments:
# - 3000 per minute per IP (~50 req/sec)
# Increase if many users share a single public IP (office/VPN).
HAPPIER_API_RATE_LIMITS_GLOBAL_MAX=3000
HAPPIER_API_RATE_LIMITS_GLOBAL_WINDOW=1 minute
# Optional: keying strategies
# Global limiter defaults to IP-keying as a storm shield.
HAPPIER_API_RATE_LIMITS_GLOBAL_KEY_STRATEGY=ip-only
# Route limits default to user-or-ip (verified user id when Bearer token is valid, else IP).
HAPPIER_API_RATE_LIMITS_ROUTE_KEY_STRATEGY=user-or-ip
#
# Hot endpoints use per-route rate limits derived from a centralized catalog.
# Env vars follow the pattern: HAPPIER_<ID>_RATE_LIMIT_MAX / HAPPIER_<ID>_RATE_LIMIT_WINDOW
# where <ID> is the uppercase snake-case id (e.g. account.profile -> ACCOUNT_PROFILE).
#
# Set *_MAX=0 to disable a specific limit.
HAPPIER_SESSION_MESSAGES_RATE_LIMIT_MAX=600
HAPPIER_SESSION_MESSAGES_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SESSION_MESSAGES_BY_LOCAL_ID_RATE_LIMIT_MAX=600
HAPPIER_SESSION_MESSAGES_BY_LOCAL_ID_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SESSIONS_LIST_RATE_LIMIT_MAX=300
HAPPIER_SESSIONS_LIST_RATE_LIMIT_WINDOW=1 minute
HAPPIER_CHANGES_RATE_LIMIT_MAX=600
HAPPIER_CHANGES_RATE_LIMIT_WINDOW=1 minute
HAPPIER_FEATURES_RATE_LIMIT_MAX=120
HAPPIER_FEATURES_RATE_LIMIT_WINDOW=1 minute
HAPPIER_MACHINES_RATE_LIMIT_MAX=300
HAPPIER_MACHINES_RATE_LIMIT_WINDOW=1 minute
HAPPIER_ARTIFACTS_RATE_LIMIT_MAX=300
HAPPIER_ARTIFACTS_RATE_LIMIT_WINDOW=1 minute
HAPPIER_FEED_RATE_LIMIT_MAX=300
HAPPIER_FEED_RATE_LIMIT_WINDOW=1 minute
HAPPIER_KV_LIST_RATE_LIMIT_MAX=600
HAPPIER_KV_LIST_RATE_LIMIT_WINDOW=1 minute
HAPPIER_ACCOUNT_PROFILE_RATE_LIMIT_MAX=300
HAPPIER_ACCOUNT_PROFILE_RATE_LIMIT_WINDOW=1 minute
HAPPIER_ACCOUNT_SETTINGS_RATE_LIMIT_MAX=300
HAPPIER_ACCOUNT_SETTINGS_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SESSION_PENDING_RATE_LIMIT_MAX=600
HAPPIER_SESSION_PENDING_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SESSION_PENDING_MATERIALIZE_RATE_LIMIT_MAX=120
HAPPIER_SESSION_PENDING_MATERIALIZE_RATE_LIMIT_WINDOW=1 minute
HAPPIER_DIAGNOSTICS_BUG_REPORT_SNAPSHOT_RATE_LIMIT_MAX=30
HAPPIER_DIAGNOSTICS_BUG_REPORT_SNAPSHOT_RATE_LIMIT_WINDOW=1 minute
HAPPIER_VOICE_TOKEN_RATE_LIMIT_MAX=10
HAPPIER_VOICE_TOKEN_RATE_LIMIT_WINDOW=1 minute
HAPPIER_VOICE_SESSION_COMPLETE_RATE_LIMIT_MAX=60
HAPPIER_VOICE_SESSION_COMPLETE_RATE_LIMIT_WINDOW=1 minute
HAPPIER_OAUTH_EXTERNAL_AUTH_PARAMS_RATE_LIMIT_MAX=60
HAPPIER_OAUTH_EXTERNAL_AUTH_PARAMS_RATE_LIMIT_WINDOW=1 minute
HAPPIER_OAUTH_EXTERNAL_CONNECT_PARAMS_RATE_LIMIT_MAX=60
HAPPIER_OAUTH_EXTERNAL_CONNECT_PARAMS_RATE_LIMIT_WINDOW=1 minute
HAPPIER_OAUTH_EXTERNAL_CALLBACK_RATE_LIMIT_MAX=60
HAPPIER_OAUTH_EXTERNAL_CALLBACK_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SHARE_PUBLIC_READ_RATE_LIMIT_MAX=10
HAPPIER_SHARE_PUBLIC_READ_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SHARE_PUBLIC_MESSAGES_RATE_LIMIT_MAX=20
HAPPIER_SHARE_PUBLIC_MESSAGES_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SHARE_PUBLIC_MANAGE_RATE_LIMIT_MAX=10
HAPPIER_SHARE_PUBLIC_MANAGE_RATE_LIMIT_WINDOW=1 minute
HAPPIER_SHARE_SESSION_CREATE_RATE_LIMIT_MAX=20
HAPPIER_SHARE_SESSION_CREATE_RATE_LIMIT_WINDOW=1 minute

############################
# S3 / MinIO public file storage (required when HAPPIER_FILES_BACKEND=s3)
############################
S3_HOST=minio
S3_PORT=9000
S3_USE_SSL=false
S3_BUCKET=happier-public
S3_PUBLIC_URL=https://files.example.com/happier-public
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me

############################
# Realtime scaling (required for multi-replica API/worker topologies)
############################
# HAPPIER_SOCKET_ADAPTER=redis-streams
# REDIS_URL=redis://redis:6379

############################
# Bug reports (server-advertised capabilities)
############################
HAPPIER_FEATURE_BUG_REPORTS__ENABLED=1
HAPPIER_FEATURE_BUG_REPORTS__PROVIDER_URL=https://reports.happier.dev
HAPPIER_FEATURE_BUG_REPORTS__DEFAULT_INCLUDE_DIAGNOSTICS=1
HAPPIER_FEATURE_BUG_REPORTS__MAX_ARTIFACT_BYTES=10485760
HAPPIER_FEATURE_BUG_REPORTS__UPLOAD_TIMEOUT_MS=120000
HAPPIER_FEATURE_BUG_REPORTS__CONTEXT_WINDOW_MS=1800000
HAPPIER_FEATURE_BUG_REPORTS__ACCEPTED_ARTIFACT_KINDS=ui-mobile,ui-desktop,cli,daemon,server,stack-service,user-note

############################
# Bug-report server diagnostics snapshot controls
############################
HAPPIER_BUG_REPORTS_SERVER_DIAGNOSTICS_ENABLED=0
# HAPPIER_BUG_REPORTS_SERVER_DIAGNOSTICS_ACCESS_MODE=authenticated
# Set to "owner" on shared servers and define owners below.
# HAPPIER_SERVER_OWNER_USER_IDS=user-id-1,user-id-2
# Optional explicit server log path (fallback uses HAPPIER_SELF_HOST_LOG_DIR/server.log).
# HAPPIER_BUG_REPORTS_SERVER_LOG_PATH=/var/log/happier/server.log
# Optional fallback log directory.
# HAPPIER_SELF_HOST_LOG_DIR=/var/log/happier
HAPPIER_BUG_REPORTS_SERVER_LOG_MAX_BYTES=262144
# Rate limit is configured via the centralized API rate limit catalog:
# - diagnostics.bugReportSnapshot -> HAPPIER_DIAGNOSTICS_BUG_REPORT_SNAPSHOT_RATE_LIMIT_*

############################
# OAuth / auth (optional)
#
# NOTE: If you enable OAuth providers and you are not using https://app.happier.dev,
# set HAPPIER_WEBAPP_URL or HAPPIER_WEBAPP_OAUTH_RETURN_URL_BASE so OAuth can redirect back to your client.
############################
# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URL=https://api.example.com/v1/oauth/github/callback
# GITHUB_HTTP_TIMEOUT_SECONDS=10
# GITHUB_STORE_ACCESS_TOKEN=false
# GITHUB_WEBHOOK_SECRET=
# HAPPIER_WEBAPP_URL=https://app.example.com
# HAPPIER_WEBAPP_OAUTH_RETURN_URL_BASE=https://app.example.com/oauth
# HAPPIER_OAUTH_RETURN_ALLOWED_SCHEMES=myapp
# OAUTH_PENDING_TTL_SECONDS=600
# OAUTH_STATE_TTL_SECONDS=600
#
# Auth policy
# AUTH_ANONYMOUS_SIGNUP_ENABLED=true
# AUTH_SIGNUP_PROVIDERS=github
# AUTH_REQUIRED_LOGIN_PROVIDERS=
# AUTH_OFFBOARDING_ENABLED=false
# AUTH_OFFBOARDING_INTERVAL_SECONDS=86400
# AUTH_OFFBOARDING_STRICT=false
# HAPPIER_FEATURE_AUTH_RECOVERY__PROVIDER_RESET_ENABLED=1
# HAPPIER_FEATURE_AUTH_UI__AUTO_REDIRECT_ENABLED=0
# HAPPIER_FEATURE_AUTH_UI__AUTO_REDIRECT_PROVIDER_ID=
# HAPPIER_FEATURE_AUTH_UI__RECOVERY_KEY_REMINDER_ENABLED=1
# Legacy aliases (still accepted):
# AUTH_RECOVERY_PROVIDER_RESET_ENABLED=true
# AUTH_UI_AUTO_REDIRECT=false
# AUTH_UI_AUTO_REDIRECT_PROVIDER_ID=
# AUTH_UI_RECOVERY_KEY_REMINDER_ENABLED=true
# AUTH_PROVIDERS_CONFIG_PATH=/etc/happier/auth-providers.json
# AUTH_PROVIDERS_CONFIG_JSON=
#
# GitHub restrictions / app mode
# AUTH_GITHUB_ALLOWED_USERS=
# AUTH_GITHUB_ALLOWED_ORGS=
# AUTH_GITHUB_ORG_MATCH=any
# AUTH_GITHUB_ORG_MEMBERSHIP_SOURCE=github_app
# AUTH_GITHUB_APP_ID=
# AUTH_GITHUB_APP_PRIVATE_KEY=
# AUTH_GITHUB_APP_INSTALLATION_ID_BY_ORG=acme=123

############################
# Friends / social (optional)
############################
# HAPPIER_FEATURE_SOCIAL_FRIENDS__ENABLED=true
# HAPPIER_FEATURE_SOCIAL_FRIENDS__ALLOW_USERNAME=false
# HAPPIER_FEATURE_SOCIAL_FRIENDS__IDENTITY_PROVIDER=
# FRIENDS_USERNAME_MIN_LEN=3
# FRIENDS_USERNAME_MAX_LEN=32
# FRIENDS_USERNAME_REGEX=^[a-z0-9_-]+$

############################
# Voice (optional)
############################
# HAPPIER_FEATURE_VOICE__ENABLED=true
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID_PROD=
# ELEVENLABS_AGENT_ID=
# HAPPIER_FEATURE_VOICE__REQUIRE_SUBSCRIPTION=true
# VOICE_FREE_SESSIONS_PER_MONTH=0
# VOICE_FREE_MINUTES_PER_MONTH=0
# VOICE_MAX_CONCURRENT_SESSIONS=1
# VOICE_MAX_SESSION_SECONDS=1200
# VOICE_MAX_MINUTES_PER_DAY=0
# Voice endpoint rate limits are configured via the centralized API rate limit catalog:
# - voice.token -> HAPPIER_VOICE_TOKEN_RATE_LIMIT_*
# - voice.sessionComplete -> HAPPIER_VOICE_SESSION_COMPLETE_RATE_LIMIT_*
# HAPPIER_VOICE_TOKEN_RATE_LIMIT_MAX=10
# HAPPIER_VOICE_TOKEN_RATE_LIMIT_WINDOW=1 minute
# HAPPIER_VOICE_SESSION_COMPLETE_RATE_LIMIT_MAX=60
# HAPPIER_VOICE_SESSION_COMPLETE_RATE_LIMIT_WINDOW=1 minute
# VOICE_LEASE_CLEANUP=false
# VOICE_LEASE_RETENTION_DAYS=30
# VOICE_LEASE_CLEANUP_INTERVAL_MS=21600000

############################
# Light flavor overrides (single-node self-hosting)
############################
# HAPPIER_DB_PROVIDER=sqlite
# HAPPIER_FILES_BACKEND=local
# HAPPIER_SERVER_LIGHT_DATA_DIR=/var/lib/happier/server-light
# HAPPIER_SERVER_LIGHT_DB_DIR=/var/lib/happier/server-light/db
# HAPPIER_SERVER_LIGHT_FILES_DIR=/var/lib/happier/server-light/files
